# Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# football-data.org -> My Account -> API Token
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_COMPETITION_CODE=WC
FOOTBALL_DATA_SEASON=2026

# Any long random string — Vercel sends this back as `Authorization: Bearer <value>`
# on cron-triggered requests when set as a Vercel env var of the same name.
CRON_SECRET=
